# =========================================================
# AEGIS — local MLX OpenAI-compatible provider (EXAMPLE)
# =========================================================
# Does NOT replace .harness/local.env (cloud). Use either:
#
#   source scripts/use_local_mlx.sh
#   ./run_aegis.sh readonly "…"
#
# Or: cp this file to .harness/local.env.mlx and source it.
#
# Prerequisites:
#   bash scripts/start_mlx_server.sh
#   (keep that terminal open)
# =========================================================

export OPENAI_API_BASE="http://127.0.0.1:8080/v1"
export OPENAI_API_KEY="local-mlx"

# --- Model id ---
# Use EXACTLY what GET /v1/models returns (or "default_model" for the
# model the server was started with).
#
# Stock mlx-lm (pip) supports 2–8 bit quants, NOT true 1-bit.
# Bonsai-27B-mlx-1bit needs PrismML's MLX fork (1-bit kernels) — see
# scripts/start_mlx_server.sh notes. On ~8GB Mac, start with a small 4bit:

export OPENAI_MODEL_READONLY_COGNITION="mlx-community/Qwen2.5-1.5B-Instruct-4bit"
# export OPENAI_MODEL_READONLY_COGNITION="default_model"

export OPENAI_MODEL_ANALYSIS="${OPENAI_MODEL_READONLY_COGNITION}"

# Mutation / Aider (same server). Prefix openai/ for Aider.
export AEGIS_MUTATION_MODEL="${OPENAI_MODEL_READONLY_COGNITION}"
export AEGIS_AIDER_MODEL="openai/${OPENAI_MODEL_READONLY_COGNITION}"

# Raw substrate: T=0 by default (deterministic JSON). Stock mlx-lm often
# rejects response_format; the provider strips it on first 400, or set:
# export AEGIS_RAW_JSON_OBJECT_FORMAT=0

# Optional: Bonsai when your stack supports 1-bit MLX:
# export OPENAI_MODEL_READONLY_COGNITION="prism-ml/Bonsai-27B-mlx-1bit"
# export AEGIS_MUTATION_MODEL="${OPENAI_MODEL_READONLY_COGNITION}"
# export AEGIS_AIDER_MODEL="openai/${OPENAI_MODEL_READONLY_COGNITION}"
